<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="match_parent"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg"
    android:clipToPadding="false">

    <!-- Header -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop"
            android:layout_marginEnd="8dp" />

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Guide Dose"
            android:textSize="14sp"
            android:textColor="#202124"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_divider"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_divider"
            android:scaleType="centerInside"
            android:layout_marginEnd="4dp"
            android:contentDescription="Divisor" />

        <ImageView
            android:id="@+id/btn_ai"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_ai"
            android:scaleType="centerInside"
            android:layout_marginEnd="4dp"
            android:contentDescription="IA" />

        <ImageView
            android:id="@+id/btn_notes"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:src="@drawable/ic_widget_notes"
            android:scaleType="centerInside"
            android:layout_marginEnd="4dp"
            android:contentDescription="Anotações" />

        <TextView
            android:id="@+id/tv_add"
            android:layout_width="28dp"
            android:layout_height="28dp"
            android:text="+"
            android:textSize="20sp"
            android:textColor="#1A73E8"
            android:gravity="center"
            android:textStyle="bold" />
    </LinearLayout>

    <ImageView
        android:layout_width="match_parent"
        android:layout_height="1dp"
        android:background="#E8EAED"
        android:layout_marginBottom="4dp"
        android:importantForAccessibility="no" />

    <!-- Events list -->
    <ListView
        android:id="@+id/lv_agenda"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:divider="@null"
        android:dividerHeight="0dp" />

    <!-- Empty state -->
    <TextView
        android:id="@+id/tv_empty"
        android:layout_width="match_parent"
        android:layout_height="0dp"
        android:layout_weight="1"
        android:text="Sem plantões nos próximos dias"
        android:textSize="13sp"
        android:textColor="#5F6368"
        android:gravity="center"
        android:visibility="gone" />

</LinearLayout>
