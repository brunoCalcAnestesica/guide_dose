<?xml version="1.0" encoding="utf-8"?>
<LinearLayout xmlns:android="http://schemas.android.com/apk/res/android"
    android:layout_width="match_parent"
    android:layout_height="wrap_content"
    android:orientation="vertical"
    android:padding="12dp"
    android:background="@drawable/widget_bg"
    android:clipToPadding="false">

    <!-- Header: Month/Year -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:gravity="center_vertical"
        android:paddingBottom="8dp">

        <TextView
            android:id="@+id/tv_month_label"
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Fevereiro 2026"
            android:textSize="16sp"
            android:textColor="#202124"
            android:textStyle="bold" />

        <ImageView
            android:id="@+id/btn_divider"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_widget_divider"
            android:scaleType="centerInside"
            android:layout_marginEnd="4dp"
            android:contentDescription="Divisor" />

        <ImageView
            android:id="@+id/btn_ai"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_widget_ai"
            android:scaleType="centerInside"
            android:layout_marginEnd="4dp"
            android:contentDescription="IA" />

        <ImageView
            android:id="@+id/btn_notes"
            android:layout_width="24dp"
            android:layout_height="24dp"
            android:src="@drawable/ic_widget_notes"
            android:scaleType="centerInside"
            android:layout_marginEnd="6dp"
            android:contentDescription="Anotações" />

        <ImageView
            android:id="@+id/iv_logo"
            android:layout_width="20dp"
            android:layout_height="20dp"
            android:src="@mipmap/ic_launcher"
            android:scaleType="centerCrop" />
    </LinearLayout>

    <!-- Day of week headers -->
    <LinearLayout
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:orientation="horizontal"
        android:paddingBottom="4dp">

        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="D"
            android:textSize="11sp"
            android:textColor="#5F6368"
            android:gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="S"
            android:textSize="11sp"
            android:textColor="#5F6368"
            android:gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="T"
            android:textSize="11sp"
            android:textColor="#5F6368"
            android:gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Q"
            android:textSize="11sp"
            android:textColor="#5F6368"
            android:gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="Q"
            android:textSize="11sp"
            android:textColor="#5F6368"
            android:gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="S"
            android:textSize="11sp"
            android:textColor="#5F6368"
            android:gravity="center" />
        <TextView
            android:layout_width="0dp"
            android:layout_height="wrap_content"
            android:layout_weight="1"
            android:text="S"
            android:textSize="11sp"
            android:textColor="#5F6368"
            android:gravity="center" />
    </LinearLayout>

    <!-- Calendar Grid -->
    <GridView
        android:id="@+id/gv_calendar"
        android:layout_width="match_parent"
        android:layout_height="wrap_content"
        android:numColumns="7"
        android:verticalSpacing="0dp"
        android:horizontalSpacing="0dp"
        android:stretchMode="columnWidth"
        android:gravity="center" />

</LinearLayout>
