# ============================================
# VARIÁVEIS DE AMBIENTE - IA MÉDICA
# ============================================
# Copie este arquivo para .env na raiz do seu projeto
# e preencha com seus valores
# ============================================

# URL da API (use o proxy Supabase em produção)
# Para usar proxy Supabase:
OPENAI_API_URL=https://SEU-PROJETO.supabase.co/functions/v1/openai-proxy

# Para usar OpenAI diretamente (não recomendado em produção):
# OPENAI_API_URL=https://api.openai.com/v1/chat/completions

# Chave da API OpenAI (só necessária se usar API direta)
# OPENAI_API_KEY=sk-...

# Modelo da OpenAI
OPENAI_MODEL=gpt-4.1

# Chave anon do Supabase (necessária para usar o proxy)
SUPABASE_ANON_KEY=eyJhbGciOiJIUzI1NiIsInR5cCI6IkpXVCJ9...

# URL do Supabase (se usar outros recursos do Supabase)
SUPABASE_URL=https://SEU-PROJETO.supabase.co

# Número de WhatsApp para suporte (opcional)
SOFIA_WHATSAPP_NUMBER=+5599999999999
