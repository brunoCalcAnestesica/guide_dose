        { "forma": "Vial 1 g lyophilized", "obs": "Invanz®" }
      ],
      "preparo": [
        { "diluicao": "IV: Reconstitute with 10 mL water/saline", "concentracao": "" },
        { "diluicao": "IV: Dilute in 50 mL 0.9% saline", "concentracao": "For infusion" },
        { "diluicao": "IV: Infuse over 30 min", "concentracao": "" },
        { "diluicao": "IM: Reconstitute with 3.2 mL 1% lidocaine (no epinephrine)", "concentracao": "" }
      ],
      "observacoes": [
        "Does NOT cover Pseudomonas aeruginosa or Acinetobacter. Spectrum: Enterobacteriaceae (including ESBL), Gram+, anaerobes.",
        "Advantage: once-daily dosing (long half-life ~4 h).",
        "May be given IM with 1% lidocaine as diluent (no vasoconstrictor).",
        "Renal adjustment: ClCr >30 → 1 g once daily; ClCr <30 → 500 mg once daily; hemodialysis: dose after session.",
        "Contraindication: allergy to carbapenems; IM with lidocaine if allergy to amide anesthetics.",
        "Indications: community infections, intra-abdominal, pneumonia, diabetic foot, complicated UTI, ESBL."
      ],
      "ajustesEspeciais": {
        "idoso": "Assess renal function. Adjust dose per ClCr.",
        "renal": "ClCr >30: 1 g once daily; ClCr <30: 500 mg once daily; hemodialysis: dose after session.",
        "hepatico": "Predominantly renal excretion. No isolated hepatic adjustment per labeling."
      }
