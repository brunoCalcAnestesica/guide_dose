    "pagina2": {
      "classe": "Carbapenêmico + inibidor da deidropeptidase renal (cilastatina evita degradação renal do imipenem); bactericida – espectro amplo.",
      "apresentacoes": [
        { "forma": "Frasco 500 mg/500 mg (imipenem/cilastatina) liofilizado", "obs": "Tienam® – proporção 1:1" }
      ],
      "preparo": [
        { "diluicao": "Reconstituir em 10 mL diluente próprio", "concentracao": "" },
        { "diluicao": "Diluir em 100 mL SF 0,9% ou SG 5%", "concentracao": "Para infusão" },
        { "diluicao": "Doses ≤500 mg: infundir em 20–30 min", "concentracao": "IV" },
        { "diluicao": "Doses >500 mg: infundir em 60 min", "concentracao": "IV" },
        { "diluicao": "Estabilidade conforme bula após reconstituição", "concentracao": "" }
      ],
      "observacoes": [
        "Espectro muito amplo: Gram+, Gram-, anaeróbios, Pseudomonas. NÃO cobre: MRSA, Enterococcus faecium, Stenotrophomonas.",
        "Cilastatina evita degradação renal do imipenem (inibidor da deidropeptidase-I).",
        "Risco de convulsão: dose >50 mg/kg, insuficiência renal, lesão SNC – usar com cautela.",
        "Ajuste renal obrigatório: ClCr 40–70 → 500 mg 6–8h; ClCr 20–40 → 250–500 mg 8–12h; ClCr <20 → 250 mg 12/12h; hemodiálise: dose após sessão.",
        "Menor atividade anti-Pseudomonas que meropenem – preferir meropenem quando Pseudomonas for alvo.",
        "Evitar em meningite (risco de convulsão, penetração SNC inferior ao meropenem)."
      ],
      "ajustesEspeciais": {
        "idoso": "Avaliar função renal. Ajuste de dose/intervalo conforme ClCr.",
        "renal": "ClCr 40–70: 500 mg 6–8h; ClCr 20–40: 250–500 mg 8–12h; ClCr <20: 250 mg 12/12h; hemodiálise: dose após sessão.",
        "hepatico": "Excreção predominantemente renal. Ajuste hepático isolado não necessário conforme bula."
      }
    },
