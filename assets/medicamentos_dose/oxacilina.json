    "pagina2": {
      "classe": "Beta-lactam antibiotic (anti-staphylococcal penicillin)",
      "apresentacoes": [
        { "forma": "Vial 500 mg", "obs": "Powder for injection" }
      ],
      "preparo": [
        { "diluicao": "Reconstitute 500 mg with 5 mL sterile water (100 mg/mL). Dilute in 50–100 mL NS or D5W for infusion.", "concentracao": "Infuse over 30–60 min (or IV push over 10 min if single dose)" }
      ],
      "observacoes": [
        "Drug of choice for MSSA (methicillin-susceptible Staphylococcus aureus). NOT active against MRSA.",
        "Resistant to staphylococcal penicillinases. Time-dependent bactericidal activity.",
        "Renal adjustment usually not required; renal excretion 30–60% and biliary.",
        "Stability: 6 h room temp; 24 h refrigerated after reconstitution.",
        "May cause interstitial nephritis, rare hepatotoxicity. Phlebitis at infusion site.",
        "Contraindicated in penicillin allergy. Cross-reactivity with penicillins. Pregnancy category B."
      ],
      "ajustesEspeciais": {
        "idoso": "Assess renal and hepatic function; usually no dose adjustment.",
        "renal": "Renal adjustment usually not required. In severe renal impairment assess per protocol.",
        "hepatico": "Partial hepatic metabolism; rare hepatotoxicity. Use with caution in severe hepatic impairment."
      }
    },
