{
  "version": "2.0.0",
  "tasks": [
    {
      "label": "GuideDose Web: Netlify Dev (site + functions)",
      "type": "shell",
      "command": "netlify dev",
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "netlify",
        "pattern": { "regexp": "^(.*)$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "(localhost:8888|Server now ready)"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    },
    {
      "label": "GuideDose Web: servidor de desenvolvimento",
      "type": "shell",
      "command": "npm run dev",
      "options": { "cwd": "${workspaceFolder}/auth" },
      "isBackground": true,
      "problemMatcher": {
        "owner": "vite",
        "pattern": { "regexp": "^(.*)$" },
        "background": {
          "activeOnStart": true,
          "beginsPattern": ".",
          "endsPattern": "localhost:5173"
        }
      },
      "presentation": {
        "reveal": "always",
        "panel": "dedicated",
        "showReuseMessage": false
      }
    }
  ]
}
